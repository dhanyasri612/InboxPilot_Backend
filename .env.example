# Supabase PostgreSQL (Project Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

FRONTEND_URL=http://localhost:5173
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8000/gmail/oauth/callback
# Primary Groq key; on rate limit the backend tries GROQ_API_KEY1 next
GROQ_API_KEY=your_first_groq_api_key
GROQ_API_KEY1=your_second_groq_api_key
# Optional: GROQ_API_KEY2, GROQ_MODEL=llama-3.3-70b-versatile
